# Supabase — copy to .env.local and fill with your project's values.
# Dashboard → Project Settings → API.

# Project URL (e.g. https://xxxxxxxx.supabase.co) — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# anon / publishable key — safe to expose to the browser; subject to RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role / secret key — SERVER ONLY. Bypasses RLS. Never expose to the
# browser and never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth mode ---

# "phone" (default) = passwordless, no-verification phone-number sign-in for a
# trusted friend group; "otp" = the original Supabase email six-digit code flow.
# Both code paths live in src/app/[locale]/(auth)/login. Safe to expose.
NEXT_PUBLIC_AUTH_MODE=phone

# Server-side secret used to derive each phone number's synthetic password
# (HMAC). Set any random string in production; only matters in "phone" mode.
# SERVER ONLY — do not prefix with NEXT_PUBLIC_.
PHONE_AUTH_SECRET=

# --- World Cup data sync (Phase 2.6) ---

# Shared secret protecting POST /api/sync. SERVER ONLY. The external scheduler must
# send `Authorization: Bearer <this value>`.
CRON_SECRET=

# Source feed for teams/fixtures/results. Optional — defaults to the openfootball
# worldcup.json (free, public, no key, covers all 104 matches of WC2026 and updates
# scores live). Override only to pin a fork/mirror or to test against a local file.
# WORLDCUP_FEED_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json
