# Supabase — copy to .env.local and fill with your project's values.
# Dashboard → Project Settings → API.

# Project URL (e.g. https://xxxxxxxx.supabase.co) — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# anon / publishable key — safe to expose to the browser; subject to RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role / secret key — SERVER ONLY. Bypasses RLS. Never expose to the
# browser and never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
